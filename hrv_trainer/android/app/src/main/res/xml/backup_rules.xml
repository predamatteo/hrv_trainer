<?xml version="1.0" encoding="utf-8"?>
<!--
  Android Auto Backup config (Android 6-11).
  Il DB SQLite di sqflite usa path_provider.getApplicationDocumentsDirectory()
  che su Android è getFilesDir()/app_flutter/. Quindi il DB è in
  app_flutter/hrv_trainer.db, NON in databases/.
-->
<full-backup-content>
    <include domain="file" path="app_flutter/"/>
    <!-- L'<exclude> richiede un <include> dello stesso dominio (lint
         FullBackupContent). Includiamo tutte le sharedpref e poi escludiamo
         quella di Flutter, che contiene solo cache UI (lingua/tema) e non
         dati di sessione: il DB sqflite vive in app_flutter/. -->
    <include domain="sharedpref" path="."/>
    <exclude domain="sharedpref" path="FlutterSharedPreferences.xml"/>
</full-backup-content>
