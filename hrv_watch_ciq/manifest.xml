<?xml version="1.0"?>
<!--
  Connect IQ app manifest per HRV Trainer.
  Target: Garmin Instinct Solar 2X (API level Connect IQ 4.1+).

  UUID16 generato (condiviso con lato Flutter/Android).
-->
<iq:manifest xmlns:iq="http://www.garmin.com/xml/connectiq" version="3">
  <iq:application
      id="53acf5c77bd74bc1bd3475f41ffec345"
      type="watch-app"
      name="@Strings.AppName"
      launcherIcon="@Drawables.LauncherIcon"
      entry="HrvTrainerApp"
      minApiLevel="3.4.0">

    <!-- Permessi necessari -->
    <iq:permissions>
      <iq:uses-permission id="Communications"/>
      <iq:uses-permission id="Sensor"/>
      <iq:uses-permission id="SensorHistory"/>
      <iq:uses-permission id="Fit"/>
    </iq:permissions>

    <!-- Lista dispositivi target. Instinct Solar 2X = instinct2x -->
    <iq:products>
      <iq:product id="instinct2x"/>
      <iq:product id="instinct2"/>
      <iq:product id="instinct2s"/>
    </iq:products>

    <iq:languages>
      <iq:language>eng</iq:language>
      <iq:language>ita</iq:language>
    </iq:languages>

    <!--
      Barrels (librerie) opzionali. Nessuna al momento.
    -->
    <iq:barrels/>
  </iq:application>
</iq:manifest>
